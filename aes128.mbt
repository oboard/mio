///|
#cfg(target="native")
priv suberror Aes128Error {
  AesBadKeyLength
  AesBadBlockLength
} derive(Debug, ToJson)

///|
#cfg(target="native")
let aes_sbox : Array[Int] = [
  0x63, 0x7c, 0x77, 0x7b, 0xf2, 0x6b, 0x6f, 0xc5, 0x30, 0x01, 0x67, 0x2b, 0xfe, 0xd7,
